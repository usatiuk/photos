{
    "compilerOptions": {
        "lib": [
            "es2017"
        ],
        "target": "es2017",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./dist",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "noImplicitAny": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "preserveSymlinks": false,
        "baseUrl": "./",
        "paths": {
            "~*": [
                "./src/*"
            ],
            // Required because for whatever reason typescript uses "real" path to
            // resolve imports, which means that importing zod in types.ts is broken otherwise
            "zod": ["node_modules/zod"]
        }
    },
    "include": [
        "./src/**/*.ts",
        "./tests/**/*.ts",
    ],
    "exclude": [
        "frontend"
    ]
}