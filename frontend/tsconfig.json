{
    "compilerOptions": {
        "lib": ["es2017", "dom"],
        "jsx": "react",
        "target": "es5",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./dist",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "noImplicitAny": false,
        "allowSyntheticDefaultImports": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "downlevelIteration": true,
        "baseUrl": "./",
        "paths": {
            "~*": [
                "./*"
            ],
            // Required because for whatever reason typescript uses "real" path to
            // resolve imports, which means that importing zod in types.ts is broken otherwise
            "zod": ["node_modules/zod"]
        }
    },
    "include": ["./src/**/*.ts", "./src/**/*.tsx", "./jest.config.js"]
}
